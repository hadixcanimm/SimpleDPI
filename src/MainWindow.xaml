<Window x:Class="SimpleDPI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleDPI" Width="330" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        Loaded="Window_Loaded" Closed="Window_Closed" StateChanged="Window_StateChanged" Icon="appicon.ico">
    
    <Window.Resources>
        <!-- Modern Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Round Icon Button -->
        <Style x:Key="RoundIconButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apple Style Toggle Switch -->
        <Style x:Key="MacToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,10,0"/>
                            <Border x:Name="Track" Grid.Column="1" Width="40" Height="22" CornerRadius="11" Background="#444444" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#0066CC"/> <!-- Theme Blue -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="18" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Text Box -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555" CornerRadius="2" Margin="0,2,0,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"/>
                            <ToggleButton x:Name="ToggleButton" BorderThickness="0" Background="Transparent" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path x:Name="Arrow" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#222222" BorderThickness="1" BorderBrush="#444444" CornerRadius="4"/>
                                    <ScrollViewer Margin="0,2">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" MaxWidth="280" FontSize="12"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Geometry x:Key="PowerIcon">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V13H13V7H11Z</Geometry>
        <Geometry x:Key="SettingsIcon">M3,17V19H9V17H3M3,5V7H13V5H3M13,21V19H21V17H13V15H11V21H13M7,9V11H3V13H7V15H9V9H7M21,13V11H11V13H21M15,9H17V7H21V5H17V3H15V9Z</Geometry>
        <Geometry x:Key="ArrowIcon">M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z</Geometry>
        <Geometry x:Key="BackIcon">M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z</Geometry>
        <Geometry x:Key="SteamIcon">M.33 10.33A8.01 8.01 0 0 0 7.99 16C12.41 16 16 12.42 16 8s-3.59-8-8.01-8A8.01 8.01 0 0 0 0 7.47l.003.006 4.304 1.769A2.2 2.2 0 0 1 5.62 8.88l1.96-2.844-.001-.04a3.046 3.046 0 0 1 3.042-3.043 3.046 3.046 0 0 1 3.042 3.043 3.047 3.047 0 0 1-3.111 3.044l-2.804 2a2.223 2.223 0 0 1-3.075 2.11 2.22 2.22 0 0 1-1.312-1.568L.33 10.33Zm4.538 2.35a1.715 1.715 0 0 0 1.318-3.165 1.7 1.7 0 0 0-1.263-.02l1.023.424a1.261 1.261 0 1 1-.97 2.33l-.99-.41a1.7 1.7 0 0 0 .882.84Zm3.726-6.687a2.03 2.03 0 0 0 2.027 2.029 2.03 2.03 0 0 0 2.027-2.029 2.03 2.03 0 0 0-2.027-2.027 2.03 2.03 0 0 0-2.027 2.027m2.03-1.527a1.524 1.524 0 1 1-.002 3.048 1.524 1.524 0 0 1 .002-3.048</Geometry>
        <Geometry x:Key="DiscordIcon">M18.942,1.987C17.512,1.334,15.992,0.857,14.39,0.583C14.372,0.579,14.352,0.589,14.341,0.606C14.153,0.941,13.945,1.381,13.8,1.721C12.059,1.46,10.33,1.46,8.618,1.721C8.473,1.381,8.257,0.941,8.069,0.606C8.057,0.588,8.038,0.579,8.019,0.583C6.42,0.857,4.897,1.334,3.465,1.987C3.455,1.992,3.447,1.999,3.442,2.008C0.552,6.326,-0.237,10.54,0.158,14.69C0.16,14.706,0.17,14.722,0.183,14.73C2.1,16.14,3.957,16.99,5.78,17.56C5.803,17.567,5.827,17.558,5.84,17.537C6.273,16.945,6.657,16.315,6.983,15.648C6.997,15.619,6.983,15.586,6.953,15.574C6.34,15.342,5.757,15.053,5.202,14.717C5.168,14.696,5.165,14.647,5.197,14.621C5.313,14.534,5.431,14.444,5.542,14.351C5.562,14.335,5.589,14.33,5.611,14.341C9.284,16.023,13.279,16.023,16.897,14.341C16.919,14.331,16.946,14.335,16.966,14.351C17.078,14.444,17.195,14.534,17.311,14.621C17.343,14.646,17.341,14.696,17.307,14.717C16.75,15.053,16.164,15.341,15.551,15.574C15.52,15.586,15.507,15.619,15.521,15.648C15.847,16.315,16.231,16.945,16.664,17.537C16.677,17.555,16.7,17.565,16.724,17.56C18.547,16.99,20.404,16.14,22.321,14.73C22.334,14.721,22.344,14.707,22.345,14.69C22.793,9.839,21.583,5.645,18.961,2.008C18.957,1.999,18.948,1.992,18.942,1.987ZM8.019,12.564C6.924,12.564,6.014,11.554,6.014,10.317C6.014,9.081,6.899,8.071,8.019,8.071C9.141,8.071,10.049,9.081,10.026,10.317C10.026,11.554,9.141,12.564,8.019,12.564ZM14.484,12.564C13.389,12.564,12.479,11.554,12.479,10.317C12.479,9.081,13.364,8.071,14.484,8.071C15.606,8.071,16.514,9.081,16.491,10.317C16.491,11.554,15.606,12.564,14.484,12.564Z</Geometry>
        <Geometry x:Key="InternetIcon">M12.87,15.07L10.33,12.56L10.36,12.53C12.1,10.59 13.34,8.36 14.07,6H17V4H10V2H8V4H1V6H12.17C11.5,7.92 10.44,9.75 9,11.35C8.07,10.32 7.3,9.19 6.69,8H4.69C5.42,9.63 6.42,11.17 7.67,12.56L2.58,17.58L4,19L9,14L12.11,17.11L12.87,15.07M18.5,10H16.5L12,22H14L15.12,19H19.87L21,22H23L18.5,10M15.88,17L17.5,12.67L19.12,17H15.88Z</Geometry>
        
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.3" Duration="0:0:1.2" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="#B0151515" CornerRadius="12" BorderBrush="#333333" BorderThickness="1" MouseDown="Window_MouseDown">
        <Grid>
            <!-- Title Bar with Back Button -->
            <Grid Height="40" VerticalAlignment="Top" Background="Transparent" Panel.ZIndex="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="BtnBack" Grid.Column="0" Style="{StaticResource RoundIconButton}" Width="30" Height="30" Margin="10,0,0,0" Visibility="Collapsed" Click="BtnBack_Click">
                    <Path Data="{StaticResource BackIcon}" Fill="White" Stretch="Uniform" Width="14"/>
                </Button>
                
                <TextBlock x:Name="LblTitle" Grid.Column="1" Text="SimpleDPI" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="14"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="−" Style="{StaticResource RoundIconButton}" Click="BtnMinimize_Click" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <Button Content="✕" Style="{StaticResource RoundIconButton}" Click="BtnClose_Click" Foreground="White" FontSize="14" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 1. MAIN VIEW -->
            <Grid x:Name="MainView" Visibility="Visible" Margin="0,50,0,20" Opacity="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="BtnToggle" Width="130" Height="130" 
                            Background="#222222" Foreground="#555555" 
                            Click="BtnToggle_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="65" BorderThickness="3" BorderBrush="{TemplateBinding Foreground}">
                                    <Path x:Name="Icon" Data="{StaticResource PowerIcon}" Fill="{TemplateBinding Foreground}" Width="54" Height="54" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#2A2A2A" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#222222" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="TxtStatus" Text="Kapalı" Foreground="#777777" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,25,0,0"/>
                </StackPanel>

                <!-- Settings Button Bottom Right -->
                <Button Style="{StaticResource RoundIconButton}" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,5" Click="BtnOpenSettings_Click">
                    <Path Data="{StaticResource SettingsIcon}" Fill="#BBBBBB" Width="20" Height="20" Stretch="Fill"/>
                </Button>
            </Grid>

            <!-- 2. SETTINGS VIEW -->
            <Grid x:Name="SettingsView" Visibility="Collapsed" Background="Transparent" Panel.ZIndex="5" Opacity="0">
                <Grid Margin="20,50,20,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nav Header: Removed title, it's in TitleBar. Added open language wheel button. -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock x:Name="LblSettings" Text="Ayarlar" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnOpenLanguage" Style="{StaticResource ModernButton}" HorizontalAlignment="Right" Width="36" Height="36" Background="#2A2A2A" Click="BtnOpenLanguage_Click">
                            <Path Data="{StaticResource InternetIcon}" Fill="#AAAAAA" Width="22" Height="22" Stretch="Uniform"/>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,15,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock x:Name="LblProfile" Text="Güç Profili" Foreground="#BBBBBB" FontSize="12" VerticalAlignment="Center"/>
                            <Button Content="?" Width="16" Height="16" Style="{StaticResource RoundIconButton}" Margin="5,0,0,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="10000" x:Name="TipProfile" Background="#333333" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbMode" ItemContainerStyle="{StaticResource DarkComboItem}" Margin="0,0,0,15" Padding="5" Height="30" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="[-5] Standart Mod (Önerilen)"/>
                            <ComboBoxItem Content="[-7] Güçlü Atlatma"/>
                            <ComboBoxItem Content="[-9] Maksimum Direnç"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock x:Name="LblDns" Text="Şifreli DNS" Foreground="#BBBBBB" FontSize="12" VerticalAlignment="Center"/>
                            <Button Content="?" Width="16" Height="16" Style="{StaticResource RoundIconButton}" Margin="5,0,0,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="10000" x:Name="TipDns" Background="#333333" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbDns" ItemContainerStyle="{StaticResource DarkComboItem}" Margin="0,0,0,20" Padding="5" Height="30" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Yandex DNS (77.88.8.8)"/>
                            <ComboBoxItem Content="Google DNS (8.8.8.8)"/>
                            <ComboBoxItem Content="Cloudflare (1.1.1.1)"/>
                            <ComboBoxItem Content="Kapalı (Açık DNS)"/>
                        </ComboBox>

                        <TextBlock x:Name="LblAdvanced" Text="Filtreler &amp; Sistem" Foreground="#999999" FontSize="12" Margin="0,0,0,8" FontWeight="Bold"/>
                        
                        <!-- Toggle Filters -->
                        <Grid Margin="0,0,0,10">
                            <CheckBox x:Name="ChkBlur" Content="Buzlu Cam (Blur) Efekti" Style="{StaticResource MacToggleSwitch}" Checked="Toggle_Blur" Unchecked="Toggle_Blur"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <CheckBox x:Name="ChkBoot" Content="Sistem Açılışında Başlat" Style="{StaticResource MacToggleSwitch}" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <CheckBox x:Name="ChkAutoStart" Content="Otomatik Hizmet Tetikle" Style="{StaticResource MacToggleSwitch}" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <CheckBox x:Name="ChkQuic" Style="{StaticResource MacToggleSwitch}" Checked="Setting_Changed" Unchecked="Setting_Changed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtQuic" Text="QUIC Protokolünü Kapat" VerticalAlignment="Center"/>
                                    <Button x:Name="TipQuic" Content="?" Width="16" Height="16" Style="{StaticResource RoundIconButton}" Margin="5,0,0,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="10000" Background="#333333" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </CheckBox>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <CheckBox x:Name="ChkReverse" Style="{StaticResource MacToggleSwitch}" Checked="Setting_Changed" Unchecked="Setting_Changed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtReverse" Text="Ters Parçalanma Kullan" VerticalAlignment="Center"/>
                                    <Button x:Name="TipReverse" Content="?" Width="16" Height="16" Style="{StaticResource RoundIconButton}" Margin="5,0,0,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="10000" Background="#333333" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </CheckBox>
                        </Grid>

                        <Button x:Name="BtnToggleManual" Content="Manuel" Style="{StaticResource ModernButton}" Height="30" Click="BtnToggleManual_Click" Background="#444444" Margin="0,0,0,10"/>
                        <!-- Animated Height Box -->
                        <Border x:Name="BrdManualBox" Height="0" ClipToBounds="True" Background="#111111" CornerRadius="4">
                            <TextBox x:Name="TxtManual" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Padding="5" TextChanged="TxtManual_TextChanged" Margin="0,0,0,5"/>
                        </Border>
                    </StackPanel>

                    <!-- Save / Reset Footer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
                        <Button x:Name="BtnResetSettings" Content="Sıfırla" Style="{StaticResource ModernButton}" Width="80" Height="32" Margin="0,0,10,0" Background="#902222" Click="BtnResetSettings_Click"/>
                        <Button x:Name="BtnSaveSettings" Content="Uygula" Style="{StaticResource ModernButton}" Width="80" Height="32" Click="BtnSaveSettings_Click" Background="#0066CC"/>
                    </StackPanel>
                </Grid>
            </Grid>
            
            <!-- 3. ABOUT VIEW -->
            <Button x:Name="BtnOpenAbout" Style="{StaticResource RoundIconButton}" Width="30" Height="30" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10" Panel.ZIndex="15" Click="BtnOpenAbout_Click" Visibility="Collapsed">
                 <TextBlock Text="!" Foreground="White" FontSize="16" FontWeight="Bold"/>
            </Button>
            
            <Border x:Name="AboutView" Visibility="Collapsed" Background="#80151515" Panel.ZIndex="18" Opacity="0" CornerRadius="12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="LblAbout" Text="Hakkında" Foreground="White" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="SimpleDPI by Hadixcanim" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Width="40" Height="40" Style="{StaticResource RoundIconButton}" Margin="0,0,15,0" Click="BtnSteam_Click">
                            <Path Data="{StaticResource SteamIcon}" Fill="White" Width="24" Height="24" Stretch="Uniform"/>
                        </Button>
                        <Button Width="40" Height="40" Style="{StaticResource RoundIconButton}" Click="BtnDiscord_Click">
                            <Path Data="{StaticResource DiscordIcon}" Fill="#5865F2" Width="26" Height="26" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 4. LANGUAGE SELECTION ONBOARDING (WHEEL PICKER) -->
            <Border x:Name="LanguageOverlay" Visibility="Collapsed" Background="#50111111" Panel.ZIndex="25" Opacity="0" CornerRadius="12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <TextBlock x:Name="TxtLangFade" Text="Merhaba" Foreground="White" FontSize="32" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,15" Opacity="1"/>
                    
                    <Grid Margin="0,0,0,15">
                        <TextBox x:Name="TxtSearch" Style="{StaticResource SearchTextBox}" Width="160" Height="28" TextChanged="TxtSearch_TextChanged"/>
                    </Grid>

                    <Grid Height="175" Width="180">
                        <ScrollViewer x:Name="LangScroll" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" ScrollChanged="LangScroll_ScrollChanged">
                            <ItemsControl x:Name="ListOnboardLang">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="35" Background="Transparent" MouseDown="OnLanguageClicked" Tag="{Binding Code}">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold" 
                                                       Opacity="{Binding Opacity}" FontSize="{Binding Size}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Very subtle Selection Highlight (No Sharp Lines) -->
                        <Border Height="35" Width="160" IsHitTestVisible="False" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#000066CC" Offset="0"/>
                                    <GradientStop Color="#100066CC" Offset="0.5"/>
                                    <GradientStop Color="#000066CC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                    
                    <Button Width="40" Height="40" Background="#0066CC" BorderThickness="0" Foreground="White" Margin="0,15,0,30" Click="BtnFinishOnboarding_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Brd" Background="{TemplateBinding Background}" CornerRadius="20">
                                    <Path Data="{StaticResource ArrowIcon}" Fill="White" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Brd" Property="Background" Value="#0052A3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 4.1 STARTUP SETTINGS ONBOARDING -->
            <Border x:Name="StartupSetupOverlay" Visibility="Collapsed" Background="#50111111" Panel.ZIndex="24" Opacity="0" CornerRadius="12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,30,20,0">
                    <TextBlock x:Name="LblOnboardBoot" Text="Otomasyon" Foreground="White" FontSize="26" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    
                    <Grid Margin="0,0,0,15" Width="200">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblOnboardBootText" Text="Sistem Açılışında Başlat" Foreground="#E0E0E0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <CheckBox x:Name="ChkOnboardBoot" Grid.Column="1" Style="{StaticResource MacToggleSwitch}" Margin="15,0,0,0" Checked="OnboardSetting_Changed" Unchecked="OnboardSetting_Changed"/>
                    </Grid>

                    <Grid Margin="0,0,0,30" Width="200">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblOnboardAutoText" Text="Hizmeti Otomatik Tetikle" Foreground="#E0E0E0" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <CheckBox x:Name="ChkOnboardAuto" Grid.Column="1" Style="{StaticResource MacToggleSwitch}" Margin="15,0,0,0" Checked="OnboardSetting_Changed" Unchecked="OnboardSetting_Changed"/>
                    </Grid>

                    <Button Width="40" Height="40" Background="#0066CC" BorderThickness="0" Foreground="White" Margin="0,15,0,30" Click="BtnFinishStartupSetup_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Brd" Background="{TemplateBinding Background}" CornerRadius="20">
                                    <Path Data="{StaticResource ArrowIcon}" Fill="White" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Brd" Property="Background" Value="#0052A3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 5. DIALOG OVERLAYS (Exit / Unsaved) -->
            <Grid x:Name="ExitOverlay" Visibility="Collapsed" Background="#A0000000" Panel.ZIndex="100" Opacity="0">
                <Border Background="#1A1A1A" CornerRadius="12" Width="260" Height="220" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#333333" BorderThickness="1" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LblOverlayMsg" Text="Ne yapmak istersiniz?" Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15" TextWrapping="Wrap" TextAlignment="Center"/>
                        <StackPanel x:Name="ExitButtons" Orientation="Vertical" HorizontalAlignment="Stretch">
                            <Button x:Name="BtnExitTrue" Content="Tamamen Çık" Style="{StaticResource ModernButton}" Height="35" Background="#AA3333" Click="BtnExitTrue_Click" Margin="0,0,0,8"/>
                            <Button x:Name="BtnExitHide" Content="Gizle" Style="{StaticResource ModernButton}" Height="35" Background="#2A2A2A" Click="BtnHide_Click" Margin="0,0,0,8"/>
                            <Button x:Name="BtnExitCancel" Content="İptal" Style="{StaticResource ModernButton}" Height="35" Background="#555555" Click="BtnOverlayCancel_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="UnsavedButtons" Orientation="Vertical" HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <Button x:Name="BtnUnsavedDiscard" Content="Kaydetmeden Çık" Style="{StaticResource ModernButton}" Height="35" Background="#AA3333" Click="BtnUnsavedDiscard_Click" Margin="0,0,0,8"/>
                            <Button x:Name="BtnUnsavedCancel" Content="İptal" Style="{StaticResource ModernButton}" Height="35" Background="#555555" Click="BtnOverlayCancel_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="ResetButtons" Orientation="Vertical" HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <Button x:Name="BtnResetTrue" Content="Evet, Sıfırla" Style="{StaticResource ModernButton}" Height="35" Background="#AA3333" Click="BtnResetTrue_Click" Margin="0,0,0,8"/>
                            <Button x:Name="BtnResetCancel" Content="İptal" Style="{StaticResource ModernButton}" Height="35" Background="#555555" Click="BtnOverlayCancel_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 6. TOAST NOTIFICATION -->
            <Border x:Name="ToastNotification" Visibility="Collapsed" Background="#2E7D32" CornerRadius="6" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0" Padding="15,8" Panel.ZIndex="30" Opacity="0">
                <TextBlock x:Name="LblToast" Text="✓ Ayarlar Uygulandı!" Foreground="White" FontSize="13" FontWeight="Bold"/>
            </Border>
            
        </Grid>
    </Border>
</Window>
